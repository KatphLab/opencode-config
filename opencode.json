{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "cors": ["{env:OPENCODE_DOMAIN}"]
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#f2cbfbefebbfef77321e4c9abc9e949826bea9d7"
  ],
  "agent": {
    "plan": {
      "options": {},
      "permission": {
        "markdown_*": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "build": {
      "options": {},
      "permission": {
        "bash": "allow",
        "apply_patch": "allow",
        "edit": "allow",
        "write": "allow"
      }
    },
    "general": {
      "options": {},
      "permission": {
        "bash": "allow"
      }
    },
    "orchestrator": {
      "model": "openai/gpt-5.3-codex",
      "options": {},
      "permission": {}
    },
    "reviewer": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p6-turbo",
      "options": {},
      "permission": {}
    },
    "feature-manager": {
      "model": "deepseek/deepseek-reasoner",
      "options": {},
      "permission": {}
    },
    "discovery": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p6-turbo",
      "options": {},
      "permission": {}
    },
    "builder": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p6-turbo",
      "options": {
        "reasoningEffort": "high"
      },
      "permission": {}
    }
  },
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": false,
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      },
      "timeout": 1200000
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "{env:SONARQUBE_URL}"
      },
      "enabled": false,
      "timeout": 60000
    }
  },
  "permission": {
    "*": "deny",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "skill": "allow"
  },
  "disabled_providers": [],
  "provider": {
    "fireworks-ai": {
      "models": {
        "accounts/fireworks/routers/kimi-k2p6-turbo": {
          "name": "Kimi K2.6 Turbo",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    }
  }
}
